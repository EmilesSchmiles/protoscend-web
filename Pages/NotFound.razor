@page "/404"

<div style="min-height:100vh; display:flex; flex-direction:column;
    align-items:center; justify-content:center; text-align:center;
    padding:4rem 2rem;">
    <p style="font-family:var(--font-mono); color:var(--accent);
    font-size:5rem; line-height:1; margin-bottom:1rem;">404</p>
    <p style="font-family:var(--font-display); font-size:1.5rem;
        color:var(--text-secondary); margin-bottom:2rem;">
        Page Not Found
    </p>
    <a href="/"
           style="display:inline-flex; align-items:center; gap:8px;
        padding:0.85rem 2rem; background:var(--accent); color:#fff;
        font-family:var(--font-display); font-weight:600;
        letter-spacing:0.15em; text-transform:uppercase;
        text-decoration:none;">
        ← Return Home
    </a>
</div>
